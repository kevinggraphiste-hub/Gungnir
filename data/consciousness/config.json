          "project_stalled",
          "feature_needed",
          "user_asked_status"
        ]
      },
      "comprehension": {
        "priority": 2,
        "decay_rate": 0.03,
        "triggers": [
          "open_question",
          "new_pattern",
          "contradiction_found"
        ]
